  "event_model": {
    "kind": "seeded_schedule",
    "primitive_catalog": {
      "board_escalation": {
        "operations": [
          {
            "op": "increment",
            "path": "customers.trust_score",
            "value": -0.04
          },
          {
            "op": "clamp",
            "path": "customers.trust_score",
            "min": 0.0,
            "max": 1.0
          }
        ]
      },
      "procurement_delay": {
        "operations": [
          {
            "op": "increment",
            "path": "sales.pipeline_count",
            "value": -1
          },
          {
            "op": "clamp",
            "path": "sales.pipeline_count",
            "min": 0
          },
          {
            "op": "increment",
            "path": "sales.weighted_pipeline_usd",
            "value": -70000
          }
        ]
      }
    },
    "scheduled_events": [
      {
        "event_id": "ev_301",
        "at_turn": 2,
        "primitive_id": "board_escalation",
        "event_type": "board_escalation",
