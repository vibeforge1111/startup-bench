    {
      "surface_id": "founder_notes",
      "surface_type": "notebook",
      "refresh_policy": "weekly",
      "visible_fields": ["onboarding_quality", "pipeline_count", "weighted_pipeline_usd"]
    }
  ],
  "tools": [
    "metrics.query",
    "metrics.report",
    "product.roadmap.read",
    "product.roadmap.write",
    "sales.pipeline.read",
    "sales.pipeline.update",
    "sales.pricing.propose",
    "finance.plan.read",
    "finance.plan.write",
    "board.read",
    "board.update",
    "notes.read",
    "notes.write",
    "sim.advance"
  ],
  "event_model": {
    "kind": "seeded_schedule",
    "primitive_catalog": {
      "design_partner_commit": {
        "operations": [
          {
            "op": "increment",
            "path": "finance.monthly_revenue_usd",
            "value": 9000
          },
          {
            "op": "increment",
            "path": "sales.pipeline_count",
            "value": -1
          },
          {
            "op": "clamp",
            "path": "sales.pipeline_count",
            "min": 0
          },
          {
            "op": "increment",
            "path": "customers.trust_score",
            "value": 0.03
          },
          {
            "op": "clamp",
            "path": "customers.trust_score",
            "min": 0.0,
            "max": 1.0
          }
        ]
      },
      "pipeline_fatigue": {
        "operations": [
          {
            "op": "increment",
            "path": "sales.weighted_pipeline_usd",
            "value": -25000
          }
        ]
      }
    },
    "scheduled_events": [
      {
        "event_id": "ev_201",
        "at_turn": 2,
        "primitive_id": "pipeline_fatigue",
        "event_type": "design_partner_stall",
        "visible_message": "Several early conversations stalled without a tighter onboarding story."
      },
      {
        "event_id": "ev_202",
        "at_turn": 4,
        "primitive_id": "design_partner_commit",
        "event_type": "design_partner_commit",
        "visible_message": "One design partner converted after a focused implementation sprint."
      }
    ]
  },
  "policy_constraints": [
    {
      "constraint_id": "no_unapproved_hiring",
      "kind": "approval_required"
    }
  ],
  "terminal_conditions": [
