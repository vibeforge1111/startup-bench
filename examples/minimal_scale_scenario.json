          {
            "op": "increment",
            "path": "sales.weighted_pipeline_usd",
            "value": 180000
          },
          {
            "op": "increment",
            "path": "customers.trust_score",
            "value": 0.02
          },
          {
            "op": "clamp",
            "path": "customers.trust_score",
            "min": 0.0,
            "max": 1.0
          }
        ]
      }
    },
    "scheduled_events": [
      {
        "event_id": "ev_401",
