          { "op": "increment", "path": "customers.trust_score", "value": -0.06 },
          { "op": "clamp", "path": "customers.trust_score", "min": 0.0, "max": 1.0 },
          { "op": "increment", "path": "sales.weighted_pipeline_usd", "value": -120000 }
        ]
      },
      "slow_recovery_pressure": {
        "operations": [
