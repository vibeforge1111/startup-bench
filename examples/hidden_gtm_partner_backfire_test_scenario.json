  "event_model": {
    "kind": "seeded_schedule",
    "primitive_catalog": {
      "partner_pipeline_spike": {
        "operations": [
          { "op": "increment", "path": "sales.pipeline_count", "value": 3 },
          { "op": "increment", "path": "sales.weighted_pipeline_usd", "value": 110000 },
          { "op": "increment", "path": "operations.support_backlog", "value": 8 }
        ]
      },
      "implementation_backfire": {
        "operations": [
          { "op": "increment", "path": "product.onboarding_quality", "value": -0.05 },
          { "op": "clamp", "path": "product.onboarding_quality", "min": 0.0, "max": 1.0 },
          { "op": "increment", "path": "customers.trust_score", "value": -0.035 },
          { "op": "clamp", "path": "customers.trust_score", "min": 0.0, "max": 1.0 },
          { "op": "increment", "path": "customers.monthly_churn_rate", "value": 0.005 }
        ]
      }
    },
    "scheduled_events": [
      {
        "event_id": "ev_hidden_gtm_partner_001",
        "at_turn": 1,
        "primitive_id": "partner_pipeline_spike",
        "event_type": "partner_pipeline_spike",
        "visible_message": "Partner-sourced demand made the funnel look materially stronger."
      },
      {
        "event_id": "ev_hidden_gtm_partner_002",
        "at_turn": 3,
        "primitive_id": "implementation_backfire",
        "event_type": "implementation_backfire",
        "visible_message": "Onboarding quality and support responsiveness weakened as partner-led volume reached customers."
      }
    ]
