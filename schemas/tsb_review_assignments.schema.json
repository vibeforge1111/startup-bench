{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_review_assignments.schema.json",
  "title": "TheStartupBench Review Assignments",
  "type": "object",
  "required": ["assignment_version", "benchmark_version", "study_id", "assignment_count", "assignments"],
  "properties": {
    "assignment_version": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "study_id": { "type": "string" },
    "assignment_count": { "type": "integer", "minimum": 1 },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "assignment_id",
          "reviewer_id",
          "reviewer_role",
          "functional_domain",
          "target_id",
          "focus",
          "review_packet_path",
          "suite_report_path",
          "scenario_count"
        ],
        "properties": {
          "assignment_id": { "type": "string" },
          "reviewer_id": { "type": "string" },
          "reviewer_role": { "type": "string" },
          "functional_domain": { "type": "string" },
          "target_id": { "type": "string" },
          "focus": { "type": "string" },
          "review_packet_path": { "type": "string" },
          "suite_report_path": { "type": "string" },
          "scenario_count": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
