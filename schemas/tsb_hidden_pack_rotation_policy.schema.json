{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_hidden_pack_rotation_policy.schema.json",
  "title": "TheStartupBench Hidden Pack Rotation Policy",
  "type": "object",
  "required": [
    "policy_version",
    "policy_id",
    "benchmark_version",
    "official_window_path",
    "rotation_cadence",
    "retirement_triggers",
    "promotion_rules",
    "operational_requirements"
  ],
  "properties": {
    "policy_version": { "type": "string" },
    "policy_id": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "official_window_path": { "type": "string" },
    "rotation_cadence": {
      "type": "object",
      "required": [
        "fresh_refresh_target",
        "test_window_boundary_rule",
        "canary_review_target",
        "minimum_rotation_review_frequency"
      ],
      "properties": {
        "fresh_refresh_target": { "type": "string" },
        "test_window_boundary_rule": { "type": "string" },
        "canary_review_target": { "type": "string" },
        "minimum_rotation_review_frequency": { "type": "string" }
      },
      "additionalProperties": false
    },
    "retirement_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "promotion_rules": {
      "type": "object",
      "required": [
        "fresh_to_test_requirements",
        "test_successor_requirements",
        "metadata_update_requirements"
      ],
      "properties": {
        "fresh_to_test_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "test_successor_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "metadata_update_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "operational_requirements": {
      "type": "object",
      "required": [
        "required_docs",
        "required_public_artifacts",
        "required_validations"
      ],
      "properties": {
        "required_docs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "required_public_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "required_validations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
