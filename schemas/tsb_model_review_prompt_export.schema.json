{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_model_review_prompt_export.schema.json",
  "title": "TheStartupBench Model Review Prompt Export",
  "type": "object",
  "required": ["export_version", "study_id", "bundle_count", "bundles"],
  "properties": {
    "export_version": { "type": "string" },
    "study_id": { "type": "string" },
    "bundle_count": { "type": "integer", "minimum": 1 },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "bundle_id",
          "target_id",
          "scenario_id",
          "track",
          "split",
          "scenario_pack_version",
          "prompt_path",
          "context_path",
          "template_path"
        ],
        "properties": {
          "bundle_id": { "type": "string" },
          "target_id": { "type": "string" },
          "scenario_id": { "type": "string" },
          "track": { "type": "string" },
          "split": { "type": "string", "enum": ["dev", "test", "fresh"] },
          "scenario_pack_version": { "type": "string" },
          "prompt_path": { "type": "string" },
          "context_path": { "type": "string" },
          "template_path": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
