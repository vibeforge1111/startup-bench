{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_calibration_study_run.schema.json",
  "title": "TheStartupBench Calibration Study Run",
  "type": "object",
  "required": [
    "run_version",
    "benchmark_version",
    "study_id",
    "target_count",
    "target_runs"
  ],
  "properties": {
    "run_version": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "study_id": { "type": "string" },
    "target_count": { "type": "integer", "minimum": 1 },
    "target_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "suite_report_path",
          "review_packet_path",
          "scenario_count",
          "validation"
        ],
        "properties": {
          "target_id": { "type": "string" },
          "suite_report_path": { "type": "string" },
          "review_packet_path": { "type": "string" },
          "scenario_count": { "type": "integer", "minimum": 1 },
          "validation": {
            "type": "object",
            "required": ["suite_report", "review_packet"],
            "properties": {
              "suite_report": { "type": "object" },
              "review_packet": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
