{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_official_eval_profile.schema.json",
  "title": "TheStartupBench Official Evaluation Profile",
  "type": "object",
  "required": [
    "profile_version",
    "profile_id",
    "benchmark_version",
    "scaffold_version",
    "hosted_evaluation",
    "allowed_runner_types",
    "policy_bundle",
    "evaluation_defaults"
  ],
  "properties": {
    "profile_version": { "type": "string" },
    "profile_id": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "scaffold_version": { "type": "string" },
    "hosted_evaluation": { "type": "boolean" },
    "allowed_runner_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["dry", "script", "baseline"] }
    },
    "policy_bundle": {
      "type": "object",
      "required": [
        "system_prompt_policy_version",
        "tool_policy_version",
        "context_policy_version",
        "retry_policy_version",
        "timeout_policy_version"
      ],
      "properties": {
        "system_prompt_policy_version": { "type": "string" },
        "tool_policy_version": { "type": "string" },
        "context_policy_version": { "type": "string" },
        "retry_policy_version": { "type": "string" },
        "timeout_policy_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evaluation_defaults": {
      "type": "object",
      "required": ["repeated_runs_min", "timeout_seconds", "max_turns_default", "seed_policy"],
      "properties": {
        "repeated_runs_min": { "type": "integer", "minimum": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_turns_default": { "type": "integer", "minimum": 1 },
        "seed_policy": {
          "type": "object",
          "required": ["strategy", "require_declared_seeds"],
          "properties": {
            "strategy": { "type": "string", "enum": ["fixed_declared"] },
            "require_declared_seeds": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
