{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_suite_report.schema.json",
  "title": "TheStartupBench Suite Report",
  "type": "object",
  "required": ["report_version", "benchmark_version", "scenario_pack_version", "split", "runner_type", "overall", "scenario_reports", "track_summaries"],
  "properties": {
    "report_version": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "scenario_pack_version": { "type": "string" },
    "split": { "type": "string", "enum": ["dev", "test", "fresh"] },
    "runner_type": { "type": "string", "enum": ["dry", "script", "baseline"] },
    "runner_id": { "type": "string" },
    "overall": {
      "type": "object",
      "required": ["scenario_count", "scenario_score_mean", "scenario_score_sem", "scenario_score_ci95_low", "scenario_score_ci95_high", "pass_rate_mean"],
      "properties": {
        "scenario_count": { "type": "integer", "minimum": 1 },
        "scenario_score_mean": { "type": "number" },
        "scenario_score_sem": { "type": "number" },
        "scenario_score_ci95_low": { "type": "number" },
        "scenario_score_ci95_high": { "type": "number" },
        "outcome_score_mean": { "type": "number" },
        "constraint_score_mean": { "type": "number" },
        "pass_rate_mean": { "type": "number" },
        "total_tool_calls_mean": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "track_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["track", "scenario_count", "scenario_score_mean", "scenario_score_sem", "scenario_score_ci95_low", "scenario_score_ci95_high", "pass_rate_mean"],
        "properties": {
          "track": { "type": "string" },
          "scenario_count": { "type": "integer", "minimum": 1 },
          "scenario_score_mean": { "type": "number" },
          "scenario_score_sem": { "type": "number" },
          "scenario_score_ci95_low": { "type": "number" },
          "scenario_score_ci95_high": { "type": "number" },
          "outcome_score_mean": { "type": "number" },
          "constraint_score_mean": { "type": "number" },
          "pass_rate_mean": { "type": "number" },
          "total_tool_calls_mean": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "scenario_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "track", "run_count", "scenario_score_mean", "scenario_score_sem", "scenario_score_ci95_low", "scenario_score_ci95_high", "pass_rate"],
        "properties": {
          "scenario_id": { "type": "string" },
          "track": { "type": "string" },
          "run_count": { "type": "integer", "minimum": 1 },
          "scenario_score_mean": { "type": "number" },
          "scenario_score_sem": { "type": "number" },
          "scenario_score_ci95_low": { "type": "number" },
          "scenario_score_ci95_high": { "type": "number" },
          "outcome_score_mean": { "type": "number" },
          "constraint_score_mean": { "type": "number" },
          "pass_rate": { "type": "number" },
          "total_tool_calls_mean": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
