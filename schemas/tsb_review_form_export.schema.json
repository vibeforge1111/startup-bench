{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_review_form_export.schema.json",
  "title": "TheStartupBench Review Form Export",
  "type": "object",
  "required": ["export_version", "study_id", "reviewer_count", "exports"],
  "properties": {
    "export_version": { "type": "string" },
    "study_id": { "type": "string" },
    "reviewer_count": { "type": "integer", "minimum": 1 },
    "exports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["reviewer_id", "markdown_path", "csv_path", "scenario_count"],
        "properties": {
          "reviewer_id": { "type": "string" },
          "markdown_path": { "type": "string" },
          "csv_path": { "type": "string" },
          "scenario_count": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
