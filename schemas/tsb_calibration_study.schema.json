{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_calibration_study.schema.json",
  "title": "TheStartupBench Calibration Study Manifest",
  "type": "object",
  "required": [
    "study_version",
    "benchmark_version",
    "study_id",
    "study_title",
    "review_targets",
    "reviewer_targets",
    "promotion_gates"
  ],
  "properties": {
    "study_version": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "study_id": { "type": "string" },
    "study_title": { "type": "string" },
    "review_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "suite_path",
          "focus",
          "baseline_runner_id",
          "seed"
        ],
        "properties": {
          "target_id": { "type": "string" },
          "suite_path": { "type": "string" },
          "focus": { "type": "string" },
          "baseline_runner_id": { "type": "string" },
          "seed": { "type": "integer", "minimum": 0 },
          "max_turns": { "type": "integer", "minimum": 1 },
          "required_scenarios": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "reviewer_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "functional_domain", "target_count"],
        "properties": {
          "role": { "type": "string" },
          "functional_domain": { "type": "string" },
          "target_count": { "type": "integer", "minimum": 1 },
          "stage_focus": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "promotion_gates": {
      "type": "object",
      "required": [
        "minimum_reviewers_per_target",
        "maximum_mean_absolute_rubric_gap",
        "minimum_recommendation_agreement_rate"
      ],
      "properties": {
        "minimum_reviewers_per_target": { "type": "integer", "minimum": 1 },
        "maximum_mean_absolute_rubric_gap": { "type": "number", "minimum": 0 },
        "minimum_recommendation_agreement_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "allow_disagreement_flags": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
