{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thestartupbench.org/schemas/tsb_review_packet.schema.json",
  "title": "TheStartupBench Review Packet",
  "type": "object",
  "required": [
    "packet_version",
    "benchmark_version",
    "study_id",
    "target_id",
    "focus",
    "suite_path",
    "suite_report_path",
    "runner_id",
    "seed",
    "required_scenarios",
    "rubric_keys",
    "scenarios"
  ],
  "properties": {
    "packet_version": { "type": "string" },
    "benchmark_version": { "type": "string" },
    "study_id": { "type": "string" },
    "target_id": { "type": "string" },
    "focus": { "type": "string" },
    "suite_path": { "type": "string" },
    "suite_report_path": { "type": "string" },
    "runner_id": { "type": "string" },
    "seed": { "type": "integer", "minimum": 0 },
    "required_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "rubric_keys": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scenario_id", "track", "title", "summary"],
        "properties": {
          "scenario_id": { "type": "string" },
          "track": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
